# ── Anthropic API key ─────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com → API Keys → Create Key
# NEVER commit the real .env.local file — it is already in .gitignore
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── Demo password protection (optional) ─────────────────────────────────────
# Set this to protect your public Vercel deployment from API credit abuse.
# Anyone visiting the URL must enter this passcode before using the app.
# Leave blank during local development — no gate will appear.
DEMO_PASSWORD=your-secret-passcode-here

# ── liteAPI (optional — live HOTEL nightly rates) ─────────────────────────────
# Free account at https://liteapi.travel → Dashboard → API Keys. Use the sandbox
# key to start. Server-side only. If unset, hotels fall back to AI estimates.
LITEAPI_API_KEY=your-liteapi-key

# ── Travelpayouts / Aviasales (optional — indicative FLIGHT prices) ───────────
# Free account at https://www.travelpayouts.com → Dashboard → for developers →
# get your API token; the marker is your affiliate id (used for deep links).
# Server-side only. If unset, flights fall back to AI estimates.
TRAVELPAYOUTS_TOKEN=your-travelpayouts-token
TRAVELPAYOUTS_MARKER=your-travelpayouts-marker
