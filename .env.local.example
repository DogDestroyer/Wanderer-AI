# ── Anthropic API key ─────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com → API Keys → Create Key
# NEVER commit the real .env.local file — it is already in .gitignore
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── Demo password protection (optional) ─────────────────────────────────────
# Set this to protect your public Vercel deployment from API credit abuse.
# Anyone visiting the URL must enter this passcode before using the app.
# Leave blank during local development — no gate will appear.
DEMO_PASSWORD=your-secret-passcode-here

# ── Amadeus Self-Service API (optional — live flight & hotel prices) ──────────
# Free account at https://developers.amadeus.com → My Self-Service Workspace →
# create an app to get your API Key + Secret. Server-side only — never exposed
# to the browser. If unset, the app falls back to AI price estimates.
AMADEUS_CLIENT_ID=your-amadeus-api-key
AMADEUS_CLIENT_SECRET=your-amadeus-api-secret
